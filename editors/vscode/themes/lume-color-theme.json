  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7e7896",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#a0d4a8"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": {
        "foreground": "#e8b4a0"
      }
    },
    {
      "scope": ["constant.other"],
      "settings": {
        "foreground": "#e8b4a0"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.language"],
      "settings": {
        "foreground": "#d8d0e4"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#b0a8c4"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#d8d0e4"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#b8a0e0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#d0a0b8"
      }
    },
    {
      "scope": ["keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.logical", "keyword.operator.comparison", "keyword.operator.ternary"],
      "settings": {
        "foreground": "#d0a0b8"
      }
    },
    {
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"],
      "settings": {
        "foreground": "#b8a0e0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#e8b4a0"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#e8b4a0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#8cc0e0"
      }
    },
    {
      "scope": ["entity.name.function.method", "meta.function-call"],
      "settings": {
        "foreground": "#8cc0e0"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#d0a0b8"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#e8b4a0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#8a8498"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#88c0b8"
      }
    },
    {
      "scope": [
        "entity.name.function.preprocessor",
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#88c0b8"
      }
    },
    {
      "scope": ["entity.name.tag.css", "support.type.property-name.css"],
      "settings": {
        "foreground": "#8cc0e0"
      }
    },
    {
      "scope": ["support.constant.property-value.css", "constant.other.color.rgb-value.css"],
      "settings": {
        "foreground": "#e8b4a0"
      }
    },
    {
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#c4b080"
      }
    },
    {
      "scope": ["entity.other.attribute-name.pseudo-class.css", "entity.other.attribute-name.pseudo-element.css"],
      "settings": {
        "foreground": "#88c0b8"
      }
    },
    {
      "scope": ["markup.heading", "markup.heading.setext"],
      "settings": {
        "foreground": "#b8a0e0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#e8b4a0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#d0a0b8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#a0d4a8"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#8cc0e0"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#a0d4a8"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#c49080"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#8cc0e0"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#d0a0b8"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#b0a8c4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["meta.separator"],
      "settings": {
        "foreground": "#8a8498"
      }
    },
    {
      "scope": ["meta.diff.header"],
      "settings": {
        "foreground": "#8cc0e0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#c49080"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#8a8498",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#e8b4a0",
    "class": "#e8b4a0",
    "enum": "#e8b4a0",
    "interface": { "foreground": "#e8b4a0", "fontStyle": "italic" },
    "struct": "#e8b4a0",
    "typeParameter": { "foreground": "#e8b4a0", "fontStyle": "italic" },
    "parameter": "#b0a8c4",
    "variable": "#d8d0e4",
    "property": "#d8d0e4",
    "enumMember": "#e8b4a0",
    "decorator": "#e8b4a0",
    "function": "#8cc0e0",
    "method": "#8cc0e0",
    "macro": "#88c0b8",
    "namespace": "#d8d0e4",
    "keyword": { "foreground": "#b8a0e0", "fontStyle": "italic" },
    "comment": { "foreground": "#7e7896", "fontStyle": "italic" },
    "string": "#a0d4a8",
    "number": "#e8b4a0",
    "operator": "#d0a0b8",
    "variable.readonly": "#e8b4a0",
    "property.readonly": { "foreground": "#d8d0e4", "fontStyle": "italic" },
    "function.defaultLibrary": { "foreground": "#8cc0e0", "fontStyle": "italic" },
    "variable.defaultLibrary": { "foreground": "#d8d0e4", "fontStyle": "italic" }
  }
}

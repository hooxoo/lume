# Lume — {{name}} ({{variant}})
# Add to your .gitconfig: [include] path = /path/to/lume.gitconfig

[delta "lume"]
    dark = true
    syntax-theme = none
    file-style = "{{foregrounds.text}}" bold
    file-decoration-style = "{{backgrounds.surface1}}" ul
    hunk-header-style = "{{foregrounds.overlay}}"
    hunk-header-decoration-style = "{{backgrounds.surface1}}" ul
    minus-style = syntax "{{backgrounds.surface0}}"
    minus-emph-style = syntax bold "{{backgrounds.surface1}}"
    plus-style = syntax "{{backgrounds.surface0}}"
    plus-emph-style = syntax bold "{{backgrounds.surface1}}"
    minus-non-emph-style = syntax "{{backgrounds.base}}"
    plus-non-emph-style = syntax "{{backgrounds.base}}"
    line-numbers = true
    line-numbers-minus-style = "{{accents.ember}}"
    line-numbers-plus-style = "{{accents.sage}}"
    line-numbers-zero-style = "{{foregrounds.overlay}}"
    line-numbers-left-style = "{{backgrounds.surface1}}"
    line-numbers-right-style = "{{backgrounds.surface1}}"
    blame-palette = "{{backgrounds.base}} {{backgrounds.surface0}} {{backgrounds.mantle}} {{backgrounds.surface1}}"
